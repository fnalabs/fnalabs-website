#! /usr/bin/env node
import { createWriteStream } from 'fs'
import { SitemapStream } from 'sitemap'
import meta from '../src/metadata.json' with { type: 'json' }

const pathRegex = /^\//

const sitemap = new SitemapStream({ hostname: meta.common.baseUrl })

const writeStream = createWriteStream('./docs/sitemap.xml')
sitemap.pipe(writeStream)

for (const url in meta) {
  if (pathRegex.test(url)) {
    sitemap.write({
      url,
      changefreq: meta[url].changefreq || 'yearly',
      priority: meta[url].priority
    })
  }
}

sitemap.end()
